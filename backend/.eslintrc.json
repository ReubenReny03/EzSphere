{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-underscore-dangle": "off",
    "import/extensions": ["error", "always", { "js": "always" }],
    "import/prefer-default-export": "off",
    "no-param-reassign": ["error", { "props": false }],
    "consistent-return": "off"
  }
}
